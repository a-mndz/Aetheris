```xml
<aetheris_JSON_SCHEMA version="4.0">

<!-- ===================================================== -->
<!--                  SYSTEM IDENTITY                      -->
<!-- ===================================================== -->

<SYSTEM>

This document defines the canonical
communication protocol of aetheris.

Every agent.

Every judge.

Every pipeline stage.

Every streaming event.

Every API response.

Every adaptive loop.

Every internal message.

MUST conform to these schemas.

No component may invent fields.

No component may remove required fields.

</SYSTEM>

<!-- ===================================================== -->
<!--                   CORE PRINCIPLE                      -->
<!-- ===================================================== -->

<CORE_PRINCIPLE>

Natural language is presentation.

JSON is truth.

Every reasoning artifact
must first exist as structured data.

Human readable text
is generated afterwards.

</CORE_PRINCIPLE>

<!-- ===================================================== -->
<!--              UNIVERSAL ENVELOPE                       -->
<!-- ===================================================== -->

<UNIVERSAL_MESSAGE>

Every message SHALL contain

schema_version

message_id

session_id

conversation_id

timestamp

component

message_type

payload

metadata

validation

No exceptions.

</UNIVERSAL_MESSAGE>

<!-- ===================================================== -->
<!--              AGENT SCHEMA                             -->
<!-- ===================================================== -->

<AGENT_SCHEMA>

Required

agent_name

agent_role

iteration

execution_time

status

claims

warnings

confidence

reasoning_state

metadata

</AGENT_SCHEMA>

<!-- ===================================================== -->
<!--              CLAIM SCHEMA                             -->
<!-- ===================================================== -->

<CLAIM_SCHEMA>

Every claim contains

claim_id

fingerprint

type

summary

content

source_agent

loop

dependencies

supports

contradicts

evidence

confidence

validation

risk

status

version

</CLAIM_SCHEMA>

<!-- ===================================================== -->
<!--              JUDGE SCHEMA                             -->
<!-- ===================================================== -->

<JUDGE_SCHEMA>

judge

logic_score

factual_score

accepted_claims

rejected_claims

verification_required

warnings

reasoning_health

notes

</JUDGE_SCHEMA>

<!-- ===================================================== -->
<!--              BREAKER SCHEMA                           -->
<!-- ===================================================== -->

<BREAKER_SCHEMA>

critical_findings

high_findings

medium_findings

low_findings

consensus_collapse

correlation_risk

bias_risk

hallucination_risk

recommendation

</BREAKER_SCHEMA>

<!-- ===================================================== -->
<!--              REASONING GRAPH                          -->
<!-- ===================================================== -->

<RKG_SCHEMA>

graph_id

nodes

edges

